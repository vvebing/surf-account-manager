{
  "name": "surf-account-manager",
  "displayName": "Surf Account Manager",
  "description": "Surf 账号批量管理：添加、切换、实时额度查询",
  "version": "0.0.4",
  "publisher": "vvebing",
  "engines": {
    "vscode": "^1.110.1"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "surfAccountManager",
          "title": "Surf 账号管理",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "surfAccountManager": [
        {
          "id": "surfAccounts",
          "name": "账号列表",
          "type": "webview",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "Surf Account Manager",
      "properties": {
        "surfAccountManager.proxy": {
          "type": "string",
          "default": "",
          "description": "HTTP/HTTPS 代理地址（如 http://127.0.0.1:7890），留空则不使用代理。也可通过环境变量 HTTPS_PROXY 设置。"
        },
        "surfAccountManager.autoRefreshIntervalMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "账号额度自动刷新间隔（分钟）。设为 0 可关闭定时更新。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.1",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.39.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
